{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!privacy-policy.html|terms-of-service.html).*)",
      "destination": "/index.html"
    }
  ]
}
